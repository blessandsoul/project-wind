                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"Anime Portrait\",\n  \"description\": \"Transform your photo into an anime-style portrait\",\n  \"category\": \"style-transfer\",\n  \"promptTemplate\": \"Transform this photo into a high-quality anime portrait. Use clean linework, vibrant colors, and anime-style eyes and features while maintaining the subject likeness.\",\n  \"providerKey\": \"gemini\",\n  \"creditCost\": 1,\n  \"sortOrder\": 10\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/templates",
                  "host": ["{{baseUrl}}"],
                  "path": ["templates"]
                },
                "description": "Create a new template. Slug is auto-generated from name if not provided."
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "if (pm.response.code === 201) {",
                      "  const res = pm.response.json();",
                      "  if (res.data && res.data.id) {",
                      "    pm.collectionVariables.set('templateId', res.data.id);",
                      "  }",
                      "}"
                    ]
                  }
                }
              ],
              "response": []
            },
